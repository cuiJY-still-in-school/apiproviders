{
  "name": "cerebras",
  "description": "Cerebras API - Fast neural network inference",
  "baseURL": "https://api.cerebras.ai/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${CEREBRAS_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "ChatCompletions",
      "path": "/chat/completions",
      "method": "POST",
      "description": "Chat completion with Cerebras models",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: llama-3.3-70b-instruct", "example": "llama-3.3-70b-instruct"},
          {"name": "messages", "type": "array", "required": true, "description": "Message array", "example": "[{\"role\": \"user\", \"content\": \"Hello\"}]"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-2)", "example": "0.7"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "1024"}
        ]
      }
    }
  ]
}