{
  "name": "siliconflow",
  "description": "SiliconFlow API - Chinese AI model hub",
  "baseURL": "https://api.siliconflow.cn/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${SILICONFLOW_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "ChatCompletions",
      "path": "/chat/completions",
      "method": "POST",
      "description": "Chat completion",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model name", "example": "deepseek-ai/DeepSeek-V3"},
          {"name": "messages", "type": "array", "required": true, "description": "Message array", "example": "[{\"role\": \"user\", \"content\": \"Hello\"}]"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-2)", "example": "0.7"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "1024"}
        ]
      }
    },
    {
      "name": "Embeddings",
      "path": "/embeddings",
      "method": "POST",
      "description": "Get embeddings",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Embedding model", "example": "BAAI/bge-m3"},
          {"name": "input", "type": "string", "required": true, "description": "Input text", "example": "Hello world"}
        ]
      }
    }
  ]
}