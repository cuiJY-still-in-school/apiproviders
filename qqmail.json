{
  "name": "qqmail",
  "description": "QQ 邮箱 / 企业邮箱 API",
  "baseURL": "https://api.aliyuncs.com",
  "docsURL": "https://cloud.tencent.com/document/product/1288",
  "auth": {
    "type": "accesskey",
    "params": {
      "accessKeyId": "${QQ_EXMAIL_SECRET_ID}",
      "accessKeySecret": "${QQ_EXMAIL_SECRET_KEY}"
    }
  },
  "models": [],
  "apis": [
    {
      "name": "SendEmail",
      "path": "/dm/send",
      "method": "POST",
      "description": "发送邮件",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "ToAddress", "type": "string", "required": true, "description": "收件人邮箱", "example": "user@example.com"},
          {"name": "Subject", "type": "string", "required": true, "description": "邮件主题", "example": "Hello"},
          {"name": "TextBody", "type": "string", "required": true, "description": "邮件正文", "example": "邮件内容"}
        ]
      }
    }
  ]
}