{
  "name": "openai",
  "description": "OpenAI API - GPT models for chat and completions",
  "baseURL": "https://api.openai.com/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${OPENAI_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "ChatCompletions",
      "path": "/chat/completions",
      "method": "POST",
      "description": "Create chat completion with GPT",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: gpt-4o, gpt-4o-mini, gpt-3.5-turbo", "example": "gpt-4o-mini"},
          {"name": "messages", "type": "array", "required": true, "description": "Message array", "example": "[{\"role\": \"user\", \"content\": \"Hello\"}]"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-2)", "example": "0.7"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "1000"},
          {"name": "stream", "type": "boolean", "required": false, "description": "Enable streaming", "example": "false"}
        ]
      }
    },
    {
      "name": "Completions",
      "path": "/completions",
      "method": "POST",
      "description": "Create text completion (legacy)",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: text-davinci-003", "example": "text-davinci-003"},
          {"name": "prompt", "type": "string", "required": true, "description": "Prompt text", "example": "Once upon a time"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "100"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-2)", "example": "0.7"}
        ]
      }
    },
    {
      "name": "Embeddings",
      "path": "/embeddings",
      "method": "POST",
      "description": "Get text embeddings",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: text-embedding-3-small, text-embedding-3-large", "example": "text-embedding-3-small"},
          {"name": "input", "type": "string", "required": true, "description": "Input text", "example": "The food was delicious"}
        ]
      }
    },
    {
      "name": "Models",
      "path": "/models",
      "method": "GET",
      "description": "List available models",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": []
      }
    }
  ]
}