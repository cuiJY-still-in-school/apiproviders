{
  "name": "xai",
  "description": "xAI API - Elon Musk's AI company with Grok models",
  "baseURL": "https://api.x.ai/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${XAI_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "ChatCompletions",
      "path": "/chat/completions",
      "method": "POST",
      "description": "Chat completion with xAI Grok models",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: grok-2, grok-2-mini, grok-1", "example": "grok-2"},
          {"name": "messages", "type": "array", "required": true, "description": "Message array", "example": "[{\"role\": \"user\", \"content\": \"Hello\"}]"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-2)", "example": "0.7"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "1024"}
        ]
      }
    }
  ]
}