{
  "name": "nvidia",
  "description": "NVIDIA AI Foundation Models API - NIM inference",
  "baseURL": "https://integrate.api.nvidia.com/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${NVIDIA_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "ChatCompletions",
      "path": "/chat/completions",
      "method": "POST",
      "description": "Chat completion with NVIDIA NIM models",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: ai-llama-3-70b-instruct, ai-mixtral-8x7b-instruct", "example": "ai-llama-3-70b-instruct"},
          {"name": "messages", "type": "array", "required": true, "description": "Message array", "example": "[{\"role\": \"user\", \"content\": \"Hello\"}]"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-2)", "example": "0.7"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "1024"}
        ]
      }
    }
  ]
}