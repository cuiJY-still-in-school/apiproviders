{
  "name": "groq",
  "description": "Groq API - Fast AI inference with Llama and Mixtral",
  "baseURL": "https://api.groq.com/openai/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${GROQ_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "ChatCompletions",
      "path": "/chat/completions",
      "method": "POST",
      "description": "Chat completion with Groq models",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.", "example": "llama-3.3-70b-versatile"},
          {"name": "messages", "type": "array", "required": true, "description": "Message array", "example": "[{\"role\": \"user\", \"content\": \"Hello\"}]"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-2)", "example": "0.7"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "1024"},
          {"name": "stream", "type": "boolean", "required": false, "description": "Enable streaming", "example": "false"}
        ]
      }
    },
    {
      "name": "ListModels",
      "path": "/models",
      "method": "GET",
      "description": "List available models",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": []
      }
    }
  ]
}