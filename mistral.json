{
  "name": "mistral",
  "description": "Mistral AI API - French AI lab models",
  "baseURL": "https://api.mistral.ai/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${MISTRAL_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "ChatCompletions",
      "path": "/chat/completions",
      "method": "POST",
      "description": "Chat completion with Mistral models",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: mistral-small, mistral-medium, mistral-large, mistral-nemo", "example": "mistral-small"},
          {"name": "messages", "type": "array", "required": true, "description": "Message array", "example": "[{\"role\": \"user\", \"content\": \"Hello\"}]"},
          {"name": "temperature", "type": "number", "required": false, "description": "Temperature (0-1)", "example": "0.7"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "1024"}
        ]
      }
    },
    {
      "name": "Completions",
      "path": "/completions",
      "method": "POST",
      "description": "Text completion",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model name", "example": "mistral-small"},
          {"name": "prompt", "type": "string", "required": true, "description": "Prompt text", "example": "Once upon a time"},
          {"name": "max_tokens", "type": "integer", "required": false, "description": "Max tokens", "example": "100"}
        ]
      }
    },
    {
      "name": "Embeddings",
      "path": "/embeddings",
      "method": "POST",
      "description": "Get embeddings",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "model", "type": "string", "required": true, "description": "Model: mistral-embed", "example": "mistral-embed"},
          {"name": "input", "type": "string", "required": true, "description": "Input text", "example": "Hello world"}
        ]
      }
    }
  ]
}