{
  "name": "gitlab",
  "description": "GitLab API - DevOps lifecycle platform",
  "baseURL": "https://gitlab.com/api/v4",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${GITLAB_TOKEN}"
    }
  },
  "apis": [
    {
      "name": "GetUser",
      "path": "/user",
      "method": "GET",
      "description": "Get current user info",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": []
      }
    },
    {
      "name": "ListProjects",
      "path": "/projects",
      "method": "GET",
      "description": "List user projects",
      "request": {
        "pathParams": [],
        "queryParams": [
          {"name": "membership", "type": "boolean", "required": false, "description": "Only show user's projects", "example": "true"},
          {"name": "per_page", "type": "integer", "required": false, "description": "Results per page", "example": "20"},
          {"name": "page", "type": "integer", "required": false, "description": "Page number", "example": "1"},
          {"name": "search", "type": "string", "required": false, "description": "Search projects", "example": "myproject"}
        ],
        "body": []
      }
    },
    {
      "name": "GetProject",
      "path": "/projects/{id}",
      "method": "GET",
      "description": "Get project by ID or path",
      "request": {
        "pathParams": [
          {"name": "id", "type": "string", "required": true, "description": "Project ID or URL-encoded path", "example": "12345 or namespace%2Fproject"}
        ],
        "queryParams": [],
        "body": []
      }
    },
    {
      "name": "ListIssues",
      "path": "/projects/{id}/issues",
      "method": "GET",
      "description": "List project issues",
      "request": {
        "pathParams": [
          {"name": "id", "type": "string", "required": true, "description": "Project ID", "example": "12345"}
        ],
        "queryParams": [
          {"name": "state", "type": "string", "required": false, "description": "Filter: opened, closed, all", "example": "opened"},
          {"name": "per_page", "type": "integer", "required": false, "description": "Results per page", "example": "20"}
        ],
        "body": []
      }
    },
    {
      "name": "CreateIssue",
      "path": "/projects/{id}/issues",
      "method": "POST",
      "description": "Create an issue",
      "request": {
        "pathParams": [
          {"name": "id", "type": "string", "required": true, "description": "Project ID", "example": "12345"}
        ],
        "queryParams": [],
        "body": [
          {"name": "title", "type": "string", "required": true, "description": "Issue title", "example": "Bug found"},
          {"name": "description", "type": "string", "required": false, "description": "Issue description", "example": "Steps to reproduce..."},
          {"name": "labels", "type": "string", "required": false, "description": "Comma-separated labels", "example": "bug,high-priority"}
        ]
      }
    },
    {
      "name": "ListMergeRequests",
      "path": "/projects/{id}/merge_requests",
      "method": "GET",
      "description": "List merge requests",
      "request": {
        "pathParams": [
          {"name": "id", "type": "string", "required": true, "description": "Project ID", "example": "12345"}
        ],
        "queryParams": [
          {"name": "state", "type": "string", "required": false, "description": "Filter: opened, closed, merged, all", "example": "opened"}
        ],
        "body": []
      }
    },
    {
      "name": "ListPipelines",
      "path": "/projects/{id}/pipelines",
      "method": "GET",
      "description": "List CI/CD pipelines",
      "request": {
        "pathParams": [
          {"name": "id", "type": "string", "required": true, "description": "Project ID", "example": "12345"}
        ],
        "queryParams": [
          {"name": "per_page", "type": "integer", "required": false, "description": "Results per page", "example": "20"}
        ],
        "body": []
      }
    },
    {
      "name": "GetFile",
      "path": "/projects/{id}/repository/files/{file_path}",
      "method": "GET",
      "description": "Get file from repository",
      "request": {
        "pathParams": [
          {"name": "id", "type": "string", "required": true, "description": "Project ID", "example": "12345"},
          {"name": "file_path", "type": "string", "required": true, "description": "File path", "example": "README.md"}
        ],
        "queryParams": [
          {"name": "ref", "type": "string", "required": false, "description": "Branch name", "example": "main"}
        ],
        "body": []
      }
    }
  ]
}