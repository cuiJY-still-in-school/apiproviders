{
  "name": "sparkpost",
  "description": "SparkPost API - Email delivery platform",
  "baseURL": "https://api.sparkpost.com/api/v1",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${SPARKPOST_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "SendEmail",
      "path": "/transmissions",
      "method": "POST",
      "description": "Send an email",
      "request": {
        "pathParams": [],
        "queryParams": [],
        "body": [
          {"name": "recipients", "type": "array", "required": true, "description": "Recipients", "example": "[{\"address\": {\"email\": \"user@example.com\"}}]"},
          {"name": "content", "type": "object", "required": true, "description": "Email content", "example": "{\"from\": {\"email\": \"sender@example.com\"}, \"subject\": \"Hello\", \"html\": \"<h1>Hello</h1>\"}"}
        ]
      }
    },
    {
      "name": "ListTemplates",
      "path": "/templates",
      "method": "GET",
      "description": "List templates",
      "request": {
        "pathParams": [],
        "queryParams": [
          {"name": "limit", "type": "integer", "required": false, "description": "Max results", "example": "20"},
          {"name": "offset", "type": "integer", "required": false, "description": "Offset", "example": "0"}
        ],
        "body": []
      }
    },
    {
      "name": "GetTemplate",
      "path": "/templates/{template_id}",
      "method": "GET",
      "description": "Get template by ID",
      "request": {
        "pathParams": [
          {"name": "template_id", "type": "string", "required": true, "description": "Template ID", "example": "template_123"}
        ],
        "queryParams": [],
        "body": []
      }
    },
    {
      "name": "GetMetrics",
      "path": "/metrics",
      "method": "GET",
      "description": "Get delivery metrics",
      "request": {
        "pathParams": [],
        "queryParams": [
          {"name": "from", "type": "string", "required": false, "description": "Start date (YYYY-MM-DD)", "example": "2024-01-01"},
          {"name": "to", "type": "string", "required": false, "description": "End date (YYYY-MM-DD)", "example": "2024-01-31"},
          {"name": "metrics", "type": "string", "required": false, "description": "Metrics to retrieve", "example": "count_sent,count_delivered"}
        ],
        "body": []
      }
    },
    {
      "name": "ListSuppressionList",
      "path": "/suppression-list",
      "method": "GET",
      "description": "List suppression entries",
      "request": {
        "pathParams": [],
        "queryParams": [
          {"name": "limit", "type": "integer", "required": false, "description": "Max results", "example": "100"},
          {"name": "offset", "type": "integer", "required": false, "description": "Offset", "example": "0"}
        ],
        "body": []
      }
    }
  ]
}