{
  "name": "huggingface",
  "description": "Hugging Face API - ML models and AI inference",
  "baseURL": "https://api-inference.huggingface.co",
  "auth": {
    "type": "bearer",
    "params": {
      "token": "${HUGGINGFACE_API_KEY}"
    }
  },
  "apis": [
    {
      "name": "Inference",
      "path": "/models/{model}",
      "method": "POST",
      "description": "Run inference on a model",
      "request": {
        "pathParams": [
          {
            "name": "model",
            "type": "string",
            "required": true,
            "description": "Model ID (e.g., gpt2, facebook/bart-large-cnn)",
            "example": "gpt2"
          }
        ],
        "queryParams": [],
        "body": [
          {
            "name": "inputs",
            "type": "string",
            "required": true,
            "description": "Input text or data",
            "example": "The movie was"
          },
          {
            "name": "parameters",
            "type": "object",
            "required": false,
            "description": "Model parameters",
            "example": "{\"max_new_tokens\": 50}"
          }
        ]
      }
    },
    {
      "name": "ListModels",
      "path": "/models",
      "method": "GET",
      "description": "List available models",
      "request": {
        "pathParams": [],
        "queryParams": [
          {
            "name": "search",
            "type": "string",
            "required": false,
            "description": "Search filter",
            "example": "text-generation"
          },
          {
            "name": "limit",
            "type": "integer",
            "required": false,
            "description": "Max results",
            "example": "20"
          },
          {
            "name": "sort",
            "type": "string",
            "required": false,
            "description": "Sort by: downloads, likes, trending",
            "example": "downloads"
          }
        ],
        "body": []
      }
    }
  ],
  "models": [
    "Qwen/Qwen3.5-397B-A17B",
    "Qwen/Qwen3-Coder-Next",
    "Qwen/Qwen3-Next-80B-A3B-Instruct",
    "Qwen/Qwen3-Embedding-8B",
    "Qwen/Qwen3-235B-A22B-Thinking-2507",
    "Qwen/Qwen3-Next-80B-A3B-Thinking",
    "Qwen/Qwen3-Embedding-4B",
    "Qwen/Qwen3-Coder-480B-A35B-Instruct",
    "zai-org/GLM-4.7-Flash",
    "zai-org/GLM-4.7",
    "zai-org/GLM-5.1",
    "zai-org/GLM-5",
    "XiaomiMiMo/MiMo-V2-Flash",
    "deepseek-ai/DeepSeek-R1-0528",
    "deepseek-ai/DeepSeek-V3.2",
    "moonshotai/Kimi-K2-Thinking",
    "moonshotai/Kimi-K2.6",
    "moonshotai/Kimi-K2-Instruct",
    "moonshotai/Kimi-K2-Instruct-0905",
    "moonshotai/Kimi-K2.5",
    "MiniMaxAI/MiniMax-M2.5",
    "MiniMaxAI/MiniMax-M2.7",
    "MiniMaxAI/MiniMax-M2.1"
  ]
}